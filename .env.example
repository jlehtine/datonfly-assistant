# Anthropic API credentials
ANTHROPIC_API_KEY=sk-ant-...

# Anthropic model to use
#
# For quick testing and development, use a smaller/cheaper model like
# claude-haiku-4-5 and disable all server-side tools.
ANTHROPIC_MODEL=claude-opus-4-7
#ANTHROPIC_MODEL=claude-sonnet-4-6
#ANTHROPIC_MODEL=claude-haiku-4-5

# Optional: model for auto-generating thread titles (omit to disable title generation)
# ANTHROPIC_TITLE_MODEL=claude-haiku-4-5

# Extended thinking / reasoning (disabled by default)
#
# ANTHROPIC_THINKING_TYPE — enable reasoning mode:
#   "adaptive"  Anthropic decides when to think based on prompt complexity (recommended)
#   "enabled"   Always think; requires ANTHROPIC_THINKING_BUDGET_TOKENS to be set
# ANTHROPIC_THINKING_TYPE=adaptive
#
# ANTHROPIC_THINKING_DISPLAY — controls how reasoning blocks appear in the response:
#   "summarized"  The model returns a concise summary of its reasoning (default when omitted)
#   "omitted"     Reasoning is performed but not included in the streamed output
# ANTHROPIC_THINKING_DISPLAY=summarized
#
# ANTHROPIC_THINKING_EFFORT — output effort level when ANTHROPIC_THINKING_TYPE=adaptive:
#   "low"    Fastest, least thorough
#   "medium" Balanced (recommended starting point)
#   "high"   More thorough, slower
#   "xhigh"  Very thorough
#   "max"    Maximum reasoning; highest latency and cost
# ANTHROPIC_THINKING_EFFORT=medium
#
# ANTHROPIC_THINKING_BUDGET_TOKENS — token budget for ANTHROPIC_THINKING_TYPE=enabled only.
# Must be a positive integer (e.g. 10000). Not used with "adaptive".
# ANTHROPIC_THINKING_BUDGET_TOKENS=10000

# Server-side tools — set to "false" to disable (all enabled by default)
# ENABLE_COMPACTION=true
# ENABLE_CODE_EXECUTION=true
# ENABLE_WEB_SEARCH=true
# ENABLE_WEB_FETCH=true

# Authentication mode: "fake" (no login, for dev/test) or "oidc" (real OIDC provider)
AUTH_MODE=fake

# Only required when AUTH_MODE=oidc
# OIDC_ISSUER_URL=https://accounts.google.com
# OIDC_CLIENT_ID=your-client-id
# OIDC_CLIENT_SECRET=your-client-secret
# OIDC_REDIRECT_URI=http://localhost:3000/auth/callback

# Optional: restrict authenticated users to a specific email domain
# OIDC_ALLOWED_EMAIL_DOMAIN=example.com

# Optional: comma-separated list of allowed email addresses.
# If set, only these addresses can authenticate. Other restrictions (e.g. domain) still apply.
# OIDC_ALLOWED_EMAILS=alice@example.com,bob@example.com

# JWT secret (auto-generated if not set; set explicitly for persistent sessions)
# JWT_SECRET=your-secret-here

# Session idle timeout in seconds (default: 604800 = 7 days).
# Both the JWT expiry and cookie maxAge are set to this value.
# The session is automatically extended on each authenticated /auth/me request.
# SESSION_TTL_SECONDS=604800

# Fake user configuration (only when AUTH_MODE=fake)
# FAKE_USER_EMAIL=dev@localhost
# FAKE_USER_NAME=Dev User

# PostgreSQL connection (enables persistence for users, threads, messages)
DATABASE_URL=postgresql://datonfly:datonfly@localhost:5432/datonfly

# Log output format: "json" for machine-parseable JSON lines, or "pretty" (default) for human-readable output
# LOG_FORMAT=json

# Log level: "trace", "debug", "info" (default), "warn", "error", "fatal"
# LOG_LEVEL=info

# Trusted reverse proxy setting (forwarded to Express "trust proxy").
# Configure this when behind ingress/reverse proxies so server-side IP checks
# use forwarded client IPs.
# Supported formats:
#   - IP/CIDR list: "10.0.0.0/8,192.168.0.0/16"
#   - hop count: "1"
#   - booleans: "true" or "false"
# TRUSTED_REVERSE_PROXY=10.0.0.0/8

# Member invite search strategy:
#   "default"              — any registered user can be discovered by partial name/email match
#   "limited-visibility"   — search only returns users who share a thread with the searcher;
#                            users not found via search can still be invited by exact email
# MEMBER_SEARCH_STRATEGY=default

# Semantic thread search (requires Qdrant + infinity-emb from docker-compose.yml)
# Set QDRANT_URL to enable; omit to disable search entirely.
QDRANT_URL=http://localhost:6333
INFINITY_URL=http://localhost:8080

# Embeddings request timeout in milliseconds. Defaults to 120000 (2 minutes).
# EMBEDDINGS_TIMEOUT_MS=120000

# Snowball stemmer language for full-text keyword matching.
# Supported: arabic, danish, dutch, english, finnish, french, german, greek, hungarian,
#            italian, norwegian, portuguese, romanian, russian, spanish, swedish, tamil, turkish.
# Omit (recommended for multi-language deployments) to disable stemming — the multilingual
# tokenizer alone gives better cross-language recall than a wrong-language stemmer.
# Only set this for single-language deployments where all content is in one known language.
# SEARCH_STEMMER_LANGUAGE=english

# Half-life for search recency decay, in days (default: 360).
# A message this many days old scores at half the weight of a message from today.
# Increase for longer-lived content, decrease to prefer only very recent threads.
# SEARCH_RECENCY_HALF_LIFE_DAYS=360

# Admin endpoints (POST /datonfly-assistant/admin/reindex)
# Both ADMIN_SECRET and ADMIN_IPS must be set for admin access to be available.
# ADMIN_SECRET — shared Bearer token for admin requests.
# ADMIN_IPS — whitespace or comma-delimited list of allowed IP addresses or CIDR ranges.
# ADMIN_SECRET=change-me-to-a-random-secret
# ADMIN_IPS=127.0.0.1 ::1
