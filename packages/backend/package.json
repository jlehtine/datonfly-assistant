    },
    "devDependencies": {
        "@langchain/core": "^1.1.39",
        "@types/cookie-parser": "^1.4.10",
        "@types/express": "^5.0.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/passport-jwt": "^4.0.1",
        "tsc-watch": "^7.2.0",
        "tsx": "^4.19.0",
        "typescript": "^6.0.2"
    }
