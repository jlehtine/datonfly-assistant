{
    "name": "@datonfly-assistant/backend",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "main": "./dist/main.js",
    "scripts": {
        "clean": "rm -rf dist",
        "build": "tsc --project tsconfig.json",
        "start": "node dist/main.js",
        "start:dev": "tsc-watch --project tsconfig.json --onSuccess \"node dist/main.js\"",
        "dev": "tsc-watch --project tsconfig.json --onSuccess \"node dist/main.js\"",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix"
    },
    "dependencies": {
        "@datonfly-assistant/agent-langchain": "workspace:*",
        "@datonfly-assistant/chat-server": "workspace:*",
        "@datonfly-assistant/core": "workspace:*",
        "@datonfly-assistant/persistence-pg": "workspace:*",
        "@nestjs/common": "^11.1.0",
        "@nestjs/config": "^4.0.0",
        "@nestjs/core": "^11.1.0",
        "@nestjs/passport": "^11.0.5",
        "@nestjs/platform-express": "^11.1.0",
        "@nestjs/serve-static": "^5.0.0",
        "cookie-parser": "^1.4.7",
        "dotenv": "^17.4.1",
        "jsonwebtoken": "^9.0.3",
        "nestjs-pino": "^4.6.1",
        "openid-client": "^6.8.2",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3",
        "reflect-metadata": "^0.2.2",
