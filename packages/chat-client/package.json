{
    "name": "@datonfly-assistant/chat-client",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./react": {
            "types": "./dist/react/index.d.ts",
            "import": "./dist/react/index.js"
        }
    },
    "typesVersions": {
        "*": {
            "react": [
                "./dist/react/index.d.ts"
            ]
        }
    },
    "scripts": {
        "clean": "rm -rf dist",
        "build": "tsc --project tsconfig.json",
        "dev": "tsc --watch --project tsconfig.json",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix"
    },
    "dependencies": {
        "socket.io-client": "^4.8.0"
    },
    "peerDependencies": {
        "@datonfly-assistant/core": "workspace:*",
        "react": "^19.0.0",
        "zod": "^4.0.0"
    },
    "peerDependenciesMeta": {
        "react": {
            "optional": true
        }
    },
    "devDependencies": {
        "@datonfly-assistant/core": "workspace:*",
        "@langchain/core": "^1.1.39",
        "@types/react": "^19.0.0",
        "react": "^19.0.0",
        "typescript": "^6.0.2"
    }
}
