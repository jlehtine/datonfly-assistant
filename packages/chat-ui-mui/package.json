{
    "name": "@datonfly-assistant/chat-ui-mui",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./rich": {
            "types": "./dist/rich.d.ts",
            "import": "./dist/rich.js"
        },
        "./emoji": {
            "types": "./dist/emoji.d.ts",
            "import": "./dist/emoji.js"
        },
        "./highlight": {
            "types": "./dist/highlight.d.ts",
            "import": "./dist/highlight.js"
        }
    },
    "scripts": {
        "clean": "rm -rf dist",
        "build": "tsc --project tsconfig.json",
        "dev": "tsc --watch --project tsconfig.json",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix"
    },
    "dependencies": {
        "i18next": "^26.0.4",
        "react-i18next": "^17.0.2",
        "react-markdown": "^10.1.0",
        "remark-gfm": "^4.0.0"
    },
    "peerDependencies": {
        "@datonfly-assistant/chat-client": "workspace:*",
        "@datonfly-assistant/core": "workspace:*",
        "@emotion/react": "^11.0.0",
        "@emotion/styled": "^11.0.0",
        "@mui/icons-material": "^7.0.0",
        "@mui/material": "^7.0.0",
        "@uiw/react-md-editor": "^4.0.0",
        "emoji-picker-react": "^4.0.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-syntax-highlighter": "^16.0.0"
    },
