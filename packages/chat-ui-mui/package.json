        },
        "react-syntax-highlighter": {
            "optional": true
        }
    },
    "devDependencies": {
        "@datonfly-assistant/chat-client": "workspace:*",
        "@datonfly-assistant/core": "workspace:*",
        "@emotion/react": "^11.0.0",
        "@emotion/styled": "^11.0.0",
        "@langchain/core": "^1.1.39",
        "@mui/material": "^7.0.0",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@types/react-syntax-highlighter": "^15.0.0",
        "@uiw/react-md-editor": "^4.0.0",
        "emoji-picker-react": "^4.0.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-syntax-highlighter": "^16.0.0",
        "typescript": "^6.0.2"
    }
