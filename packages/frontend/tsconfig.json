{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "outDir": "dist",
        "rootDir": "src",
        "jsx": "react-jsx",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "declaration": false,
        "declarationMap": false,
        "sourceMap": false,
        "verbatimModuleSyntax": false,
        "noEmit": true
    },
    "include": ["src", "vite-env.d.ts", "vite.config.ts"]
}
